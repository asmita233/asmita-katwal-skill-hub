{
  "name": "server",
  "version": "1.0.0",
  "description": "Edemy LMS Backend API",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "test": "jest --verbose --forceExit --detectOpenHandles"
  },
  "jest": {
    "testMatch": ["**/tests/test_*.js"],
    "testTimeout": 10000,
    "setupFilesAfterEnv": ["./jest.setup.js"],
    "moduleNameMapper": {
      "^uuid$": "<rootDir>/tests/__mocks__/uuid.js"
    }
  },
  "keywords": [
    "lms",
    "learning",
    "education",
    "courses"
  ],
  "author": "Asmita",
  "license": "ISC",
  "dependencies": {
    "@clerk/express": "^1.7.60",
    "cloudinary": "^2.8.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "mongoose": "^9.1.1",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "nodemon": "^3.1.11",
    "stripe": "^20.1.0",
    "svix": "^1.42.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  }
}
